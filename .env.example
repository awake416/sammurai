## LLM — choose one mode
# Personal / open-source (default): get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Enterprise (LiteLLM proxy — internal routing, optional):
# LITELLM_BASE_URL=https://your-litellm-url.com
# LITELLM_API_KEY=your-litellm-api-key

## Application
APP_ENV=development
APP_PORT=8080
APP_HOST=0.0.0.0

## Logging
LOG_LEVEL=INFO

## Database
# Path inside the container for the SQLite database
DATABASE_URL=sqlite:////app/whatsapp-data/db/sammurai.db

## WhatsApp Credentials (sensitive — never commit real values)
# Data directory for session and message persistence
WHATSAPP_DATA_DIR=/app/whatsapp-data
WHATSAPP_SESSION_PATH=/app/whatsapp-data/session

# macOS: security find-generic-password -s sammurai -a whatsapp_token -w
# Linux: pass show sammurai/whatsapp_token || keyctl pipe <key-id>
# Windows: powershell -Command "(Get-StoredCredential -Target sammurai_whatsapp_token).Password"
WHATSAPP_TOKEN=# Retrieved from vault — see scripts/inject-secrets.sh

# macOS: security find-generic-password -s sammurai -a whatsapp_phone_number_id -w
# Linux: pass show sammurai/whatsapp_phone_number_id
# Windows: powershell -Command "(Get-StoredCredential -Target sammurai_whatsapp_phone_number_id).Password"
WHATSAPP_PHONE_NUMBER_ID=# Retrieved from vault — see scripts/inject-secrets.sh

# macOS: security find-generic-password -s sammurai -a whatsapp_verify_token -w
# Linux: pass show sammurai/whatsapp_verify_token
# Windows: powershell -Command "(Get-StoredCredential -Target sammurai_whatsapp_verify_token).Password"
WHATSAPP_VERIFY_TOKEN=# Retrieved from vault — see scripts/inject-secrets.sh

# macOS: security find-generic-password -s sammurai -a whatsapp_api_key -w
# Linux: pass show sammurai/whatsapp_api_key
# Windows: powershell -Command "(Get-StoredCredential -Target sammurai_whatsapp_api_key).Password"
WHATSAPP_API_KEY=# Retrieved from vault — see scripts/inject-secrets.sh

## Fallback encrypted store
# If native OS vaults are unavailable, secrets are read from this age-encrypted file
SECRETS_FILE_PATH=./secrets/sammurai.age