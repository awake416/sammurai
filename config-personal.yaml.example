# WhatsApp Action Item Extractor Configuration - PERSONAL

llm:
  model: "claude-sonnet-4.6"
  confidence_threshold: 0.75
  batch_size: 10

# Database
database:
  path: "~/.wacli/wacli.db"

# Parser
parser:
  use_llm: true
  fallback_to_rule_based: true

# Parallel processing
parallel:
  # Personal groups: family, community, building management
  # Replace with your WhatsApp group JIDs from wacli database
  groups:
    - "GROUP_JID_1"
    - "GROUP_JID_2"
    - "GROUP_JID_3"

  workers: 5
  batch_workers: 3

# Wiki (Second Brain) - PERSONAL
wiki:
  path: "~/sammurai-brain-personal"
  schema: "SCHEMA.md"
  dataset_name: "sammurai_personal"

# Cron / Daily Digest
cron:
  days: 1
  groups: []

# Embeddings for RAG
embeddings:
  model: "text-embedding-3-small"

# Agent (Hermes - WhatsApp query interface)
agent:
  brain_chat_jid: "YOUR_PHONE_NUMBER@s.whatsapp.net"  # Replace with your WhatsApp number
  poll_interval: 1800
  rate_limit: 10
  wacli_path: "wacli"

# Email Sync (Gmail API) - PERSONAL
email:
  enabled: true
  database:
    path: "~/.emailsync/email-personal.db"
  sync:
    poll_interval: 300
    max_results_per_sync: 1000  # Backfill last 3 months on first sync
    labels_to_sync:
      - "INBOX"
      - "IMPORTANT"
      - "CATEGORY_UPDATES"
    skip_labels:
      - "SPAM"
      - "[Gmail]/Sent Mail"
      - "[Gmail]/Trash"
    from_filters:  # Personal email domains to monitor
      - "example.com"
      - "your-bank.com"
      # Add your actual email domains here
    subject_filters:
      use_llm_classifier: true
      include_keywords:
        - "closure"
        - "intimation"
        - "repo rate"
        - "certificate"
        - "statement"
        - "notice"
        - "important"
      exclude_keywords:
        - "offer"
        - "convert"
        - "emi"
        - "hassle-free"
        - "big spend"
        - "fraud alert"
        - "stay cautious"
        - "stay protected"
        - "stay alert"
        - "spot"
        - "discover"
        - "know how"
        - "scam"
    attachment_types:
      - "application/pdf"
      - "image/jpeg"
      - "image/png"
